NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# Z.AI / GLM
ZAI_API_KEY=replace-with-your-zai-api-key
ZAI_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=ilmu-glm-5.1

# Disaster signal sources
NEWSAPI_KEY=replace-with-your-newsapi-key
BERNAMA_FEED_URL=replace-with-your-bernama-feed-url
MALAYSIAKINI_FEED_URL=replace-with-your-malaysiakini-feed-url
NST_FEED_URL=replace-with-your-nst-feed-url
NADMA_ALERTS_URL=replace-with-your-nadma-alerts-url
SOCIAL_SIGNAL_SOURCE_URL=replace-with-your-social-signal-source-url

# WhatsApp provider
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=replace-with-your-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Campaign publishing
META_GRAPH_API_BASE=https://graph.facebook.com
META_ACCESS_TOKEN=replace-with-your-meta-access-token
META_FACEBOOK_PAGE_ID=replace-with-your-facebook-page-id
META_INSTAGRAM_ACCOUNT_ID=replace-with-your-instagram-account-id

# Maps / geocoding
GOOGLE_MAPS_API_KEY=replace-with-your-google-maps-api-key
GOOGLE_GEOCODING_API_KEY=replace-with-your-google-geocoding-api-key
