NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PASSWORD_RESET_CODE_SECRET=change-this-reset-secret

# Twilio SMS for sending 4-digit password reset verification code
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-login
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM="Donation Platform <your-verified-sender@example.com>"

# Z.AI GLM — OpenAI-compatible /chat/completions (see src/app/lib/donation-assistant-workflow.ts)
# ZAI_API_KEY=
# Z_AI_API_KEY=        # optional alias if your key is stored with underscore naming
# ZAI_API_BASE=https://api.z.ai/api/paas/v4
# Alternative (China): https://open.bigmodel.cn/api/paas/v4
# ILMU Anthropic-compatible gateway (uses /v1/messages payload):
# ZAI_API_BASE=https://api.ilmu.ai/anthropic
# GLM_MODEL=glm-4-flash
# GLM_VISION_MODEL=glm-4v-plus
# Optional Anthropic model overrides when using ILMU Anthropic gateway:
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_VISION_MODEL=claude-3-5-sonnet-latest
# BIGMODEL_API_KEY=   # optional alias for ZAI_API_KEY
# BIGMODEL_API_BASE=  # optional alias for ZAI_API_BASE
# ZAI_MODEL=          # optional alias for GLM_MODEL
# ZAI_VISION_MODEL=   # optional alias for GLM_VISION_MODEL
